# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# turbopack
.turbo/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OS
.DS_Store
Thumbs.db

# editors
/.idea/
/.vscode/
*.swp
*.swo
*~

# certificates
*.pem

# Envato template (licensed reference — do NOT redistribute)
/envato/

# Adobe Illustrator source files (large binaries, not used by build)
*.ai

# Original source docs (kept locally, not in repo)
website_content.docx

# Claude Code workspace
.claude/
